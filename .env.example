# ZAUR Webmail — runtime config
PUBLIC_JMAP_SERVER_URL=https://mail.zaur.app
PUBLIC_APP_NAME=ZAUR Webmail

# Required in production — encrypts the httpOnly session cookie (min 32 chars)
SESSION_SECRET=change-me-to-a-long-random-string

# Web Push (optional — generate with: node scripts/generate-vapid-keys.mjs)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@example.com

# Optional override for push subscription storage (defaults to .data/push-subscriptions.json)
# PUSH_SUBSCRIPTIONS_PATH=
