# Stalwart mail server connection
STALWART_URL=https://mail.zaur.app
STALWART_JMAP_PATH=/jmap

# Authentication — prefer STALWART_TOKEN over password in production
STALWART_ADMIN_USER=admin
STALWART_ADMIN_PASSWORD=
STALWART_TOKEN=

# Optional comma-separated domain allowlist (empty = all enabled domains from Stalwart)
REGISTRATION_DOMAINS=

# Session secret — generate with: openssl rand -hex 32
SESSION_SECRET=

# Server
PORT=3000
NODE_ENV=development

# Public-facing URLs shown on success page
WEBMAIL_URL=https://bulwark.zaur.app
MAIL_HOST=mail.zaur.app

# Free tier disk quota in bytes (default 500 MB)
MAX_DISK_QUOTA=524288000

# ── CapRover deployment ──────────────────────────────────────────────
# 1. Create app "newinternet" on CapRover
# 2. Add custom domain newinternet.online and enable SSL
# 3. Set all env vars above in CapRover dashboard (never commit .env)
# 4. Deploy: caprover deploy -a newinternet
# 5. Ensure Stalwart admin has sysAccountCreate, sysAccountQuery, sysDomainQuery
