# ListenBrainz user (MusicBrainz username)
LB_USER=nomideusz

# Required by ListenBrainz API — include a contact email or URL
LB_USER_AGENT=zaur-lb-ingest/1.0 (you@example.com)

# Tracks to attempt per run (queued, not necessarily downloaded in this run)
BATCH_SIZE=5

# mediacms-ingest container paths (defaults match production on zaur-vps)
QUEUE_DIR=/discover-queue
STATE_DIR=/data/state
SEEN_LB=/data/state/seen-lb-mbids.txt
COOKIES=/data/state/cookies.txt

# LB Radio fallback when CF recommendations are not ready (HTTP 204)
LB_RADIO_MODE=medium
LB_RADIO_POP_BEGIN=0
LB_RADIO_POP_END=100
