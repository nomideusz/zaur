{
  "name": "@zaur/mobile",
  "version": "0.1.0",
  "private": true,
  "description": "Capacitor native shell for ZAUR Mail (loads the live webmail)",
  "scripts": {
    "sync": "cap sync",
    "android": "cap run android",
    "build:android": "cd android && ./gradlew assembleDebug",
    "build:android:release": "cap sync android && cd android && ./gradlew bundleRelease"
  },
  "dependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/push-notifications": "^8.1.1"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^7.0.0",
    "sharp": "^0.35.3"
  }
}
