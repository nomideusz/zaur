# ZAUR Webmail — runtime config
PUBLIC_JMAP_SERVER_URL=https://mail.zaur.app
PUBLIC_APP_NAME=ZAUR Webmail

# Required in production — encrypts the httpOnly session cookie (min 32 chars)
SESSION_SECRET=change-me-to-a-long-random-string

# Web Push (optional — generate with: node scripts/generate-vapid-keys.mjs)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@example.com

# Optional override for push subscription storage (defaults to .data/push-subscriptions.json)
# PUSH_SUBSCRIPTIONS_PATH=/app/.data/push-subscriptions.json

# Optional bearer token for GET/POST /api/push/admin (list subscriptions, send test push)
# PUSH_ADMIN_TOKEN=

# Optional passkey/OIDC sign-in via Logto (see infra/auth/README.md)
# OAUTH_ENABLED=true
# OAUTH_ISSUER_URL=https://auth.zaur.app/oidc
# OAUTH_CLIENT_ID=<logto-app-id>
# OAUTH_CLIENT_SECRET=<logto-app-secret>   # required for "Traditional web" apps
# Do NOT set OAUTH_RESOURCE with Stalwart — use opaque Logto userinfo tokens
# OAUTH_SCOPES=openid profile email offline_access
# OAUTH_PASSWORD_FALLBACK=false  # set to disable password form and require passkey/OIDC

# Forgot password (webmail proxies to register API)
# REGISTER_API_URL=https://register.zaur.app
# PASSWORD_RESET_ENABLED=false  # set to disable forgot-password UI and API
