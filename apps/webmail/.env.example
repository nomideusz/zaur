# Webmail — runtime config.
# Minimum viable setup: PUBLIC_JMAP_SERVER_URL + SESSION_SECRET. With nothing
# else set, password sign-in (HTTP Basic to your JMAP server) is enabled.

# Base URL of your JMAP server (Stalwart). Required in production.
PUBLIC_JMAP_SERVER_URL=https://mail.example.com
PUBLIC_APP_NAME=Webmail

# Required in production — seals credentials in the server-side session store (min 32 chars).
# The httpOnly cookie contains only an opaque session id.
SESSION_SECRET=change-me-to-a-long-random-string

# Optional signup service (e.g. the zaur `register` app). Unset = every
# "get an address" entry point is hidden; create accounts in Stalwart directly.
# PUBLIC_REGISTER_URL=https://register.example.com

# Number of trusted reverse-proxy hops used to resolve the client IP for rate limits.
# Dokploy/Traefik is 1; use 2 when a trusted CDN is in front of Traefik.
# TRUSTED_PROXY_HOPS=1

# Server-side JMAP base URL override for split-horizon networks (e.g. the mail
# server reachable as http://mail:8080 inside a Docker network while browsers
# use PUBLIC_JMAP_SERVER_URL).
# JMAP_INTERNAL_URL=

# Web Push (optional — generate with: node scripts/generate-vapid-keys.mjs)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@example.com
# Optional Firebase service-account JSON for FCM push to the mobile apps.
# FCM_SERVICE_ACCOUNT=

# Optional override for push subscription storage (defaults to .data/push-subscriptions.json)
# PUSH_SUBSCRIPTIONS_PATH=/app/.data/push-subscriptions.json

# Server SQLite store — sessions + rate limits (defaults to .data/store.sqlite).
# On first boot any legacy .data/sessions.json is imported and renamed *.imported.
# STORE_DB_PATH=/app/.data/store.sqlite

# Error tracking (optional) — Sentry DSN. When set, browser
# errors report through the same-origin /api/errors tunnel and server errors post
# directly. Unset = error tracking disabled. Structured JSON request logs are
# always on (stdout).
# PUBLIC_SENTRY_DSN=
# PUBLIC_SENTRY_ENVIRONMENT=production
# Server-only DSN override (falls back to PUBLIC_SENTRY_DSN)
# SENTRY_DSN=

# --- Sign-in method -----------------------------------------------------------
# Default (nothing set): password sign-in via HTTP Basic to the JMAP server; the
# password is AES-sealed in the server-side session store. Recommended upgrade:
# register an OAuth client in Stalwart and enable the block below — then tokens
# are stored instead of the password.
#
# STALWART_OAUTH_ENABLED=false
# STALWART_OAUTH_ISSUER_URL=https://mail.example.com
# STALWART_OAUTH_CLIENT_ID=webmail
# STALWART_OAUTH_CLIENT_SECRET=  # optional for a public PKCE client
# STALWART_OAUTH_REDIRECT_URI=https://webmail.example.com/api/auth/oauth/callback
# STALWART_OAUTH_SCOPES=offline_access urn:ietf:params:oauth:scope:mail urn:ietf:params:oauth:scope:contacts urn:ietf:params:oauth:scope:calendars
#
# Password sign-in override (tri-state; see oauth-config.ts):
#   unset → enabled unless STALWART_OAUTH_ENABLED=true (fresh-deploy default)
#   true  → always enabled. Emergency lever if OAuth breaks — but ALSO clear
#           STALWART_OAUTH_ENABLED, or the endpoint still tries OAuth first.
#   false → always disabled
# STALWART_PASSWORD_LOGIN_ROLLBACK_ENABLED=

# Optional bearer token for GET/POST /api/push/admin (list subscriptions, send test push)
# PUSH_ADMIN_TOKEN=

# Forgot password (webmail proxies to the register service's API). Reset stays
# disabled until REGISTER_API_URL is set; PASSWORD_RESET_ENABLED=false
# force-disables it even then.
# REGISTER_API_URL=https://register.example.com
# PASSWORD_RESET_ENABLED=

# Signed server-to-server recovery-email API. The same random secret must be
# configured as WEBMAIL_INTERNAL_SECRET in the register service.
# REGISTER_INTERNAL_URL=https://register.example.com
# REGISTER_INTERNAL_SECRET=
