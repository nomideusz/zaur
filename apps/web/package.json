{
	"name": "@zaur/web",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"description": "Marketing site for the Zaur suite (zaur.app) — Mail, Chat, Discuss.",
	"scripts": {
		"predev": "node ../../packages/ui/scripts/build-css.mjs",
		"dev": "vite dev",
		"prebuild": "node ../../packages/ui/scripts/build-css.mjs",
		"build": "vite build",
		"preview": "vite preview",
		"prestart": "node ../../packages/ui/scripts/build-css.mjs",
		"start": "node static-server.mjs",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json"
	},
	"engines": {
		"node": ">=20"
	},
	"devDependencies": {
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/node": "^25.9.1",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.2",
		"vite": "^8.0.7"
	},
	"dependencies": {
		"@nomideusz/zaur-world": ">=0.12.0 <1",
		"@zaur/sprite": "workspace:*",
		"@zaur/ui": "workspace:*"
	}
}
