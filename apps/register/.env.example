# Stalwart mail server connection
STALWART_URL=https://mail.zaur.app
STALWART_JMAP_PATH=/jmap

# Authentication — prefer STALWART_TOKEN over password in production
STALWART_ADMIN_USER=admin
STALWART_ADMIN_PASSWORD=
STALWART_TOKEN=

# Optional: Stalwart PostgreSQL SQL directory id (auto-detected if unset)
# STALWART_PG_DIRECTORY_ID=iuip2kx7acqd


# PostgreSQL auth database (Stalwart SQL directory — mailbox passwords)
PG_HOST=srv-captain--auth-db
PG_PORT=5432
PG_DATABASE=stalwart_auth
PG_USER=postgres
PG_PASSWORD=

# Session secret — generate with: openssl rand -hex 32
SESSION_SECRET=

# Server
PORT=3000
NODE_ENV=development

# Public-facing URLs shown on success page
WEBMAIL_URL=https://webmail.zaur.app
MAIL_HOST=mail.zaur.app

# Public register URL
REGISTER_PUBLIC_URL=https://register.zaur.app

# Registration is open (invitations have been removed).
# REGISTRATION_OPEN=true

# Optional invitation audit file (CapRover persistent volume recommended)
# INVITATIONS_AUDIT_PATH=/app/data/invitations_audit.json
# INVITATION_EXPIRES_SEC=259200

# Optional SMTP — admin panel sends invitation emails automatically
# Also used for password reset emails (forgot password on webmail)
#
# CapRover: srv-captain--mail only exposes HTTP internally — SMTP is NOT on port 25
# there. Use the public submission endpoint with a mailbox login:
# INVITE_SMTP_HOST=mail.zaur.app
# INVITE_SMTP_PORT=465
# INVITE_SMTP_SECURE=true
# INVITE_SMTP_TLS_SERVERNAME=mail.zaur.app
# INVITE_SMTP_USER=noreply@zaur.app
# INVITE_SMTP_PASSWORD=…
# INVITE_SMTP_FROM=noreply@zaur.app
# INVITE_SMTP_FROM_NAME=ZAUR
#
# INVITE_SMTP_FROM_NAME=ZAUR
#
# Address-request applications (browse + apply flow) are emailed here.
# Defaults to bartek@zaur.app. Requires INVITE_SMTP_* to be configured.
# APPLICATION_TO=bartek@zaur.app
# PASSWORD_RESET_EMAIL_SUBJECT=Reset your ZAUR password
# PASSWORD_RESET_EXPIRES_SEC=3600
# PASSWORD_RESET_TOKENS_PATH=/app/data/password_reset_tokens.json

# Free tier disk quota in bytes (default 500 MB)
MAX_DISK_QUOTA=524288000

# ── CapRover deployment ──────────────────────────────────────────────
# 1. CapRover app name: register (served at register.zaur.app)
# 2. Set all env vars above in CapRover dashboard (never commit .env)
# 3. Deploy from monorepo root: pnpm deploy:register
#    (tarball is apps/register only; captain-definition path: ./captain-definition)
