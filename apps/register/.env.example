# Stalwart mail server connection
STALWART_URL=https://mail.zaur.app
STALWART_JMAP_PATH=/jmap

# Authentication — prefer STALWART_TOKEN over password in production
STALWART_ADMIN_USER=admin
STALWART_ADMIN_PASSWORD=
STALWART_TOKEN=

# Optional comma-separated domain allowlist (empty = all enabled domains from Stalwart)
REGISTRATION_DOMAINS=

# LLDAP directory — single source of truth for user passwords.
# New accounts are created here (GraphQL) and their password is set over LDAP
# (ldappasswd, requires openldap-clients in the image — see Dockerfile).
LLDAP_URL=http://srv-captain--lldap:17170
LLDAP_LDAP_URL=ldap://srv-captain--lldap:3890
LLDAP_BASE_DN=dc=zaur,dc=app
LLDAP_USERS_OU=ou=people
LLDAP_ADMIN_USER=lldapadmin
LLDAP_ADMIN_PASSWORD=
# Optional: override the admin bind DN (defaults to uid=<user>,<ou>,<base>)
# LLDAP_ADMIN_DN=uid=lldapadmin,ou=people,dc=zaur,dc=app

# Session secret — generate with: openssl rand -hex 32
SESSION_SECRET=

# Server
PORT=3000
NODE_ENV=development

# Public-facing URLs shown on success page
WEBMAIL_URL=https://webmail.zaur.app
MAIL_HOST=mail.zaur.app

# Free tier disk quota in bytes (default 500 MB)
MAX_DISK_QUOTA=524288000

# ── CapRover deployment ──────────────────────────────────────────────
# 1. CapRover app name: register (served at register.zaur.app)
# 2. Set all env vars above in CapRover dashboard (never commit .env)
# 3. Deploy from monorepo root: pnpm deploy:register
